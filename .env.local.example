# FedEx API credentials (from https://developer.fedex.com)
FEDEX_CLIENT_ID=your-fedex-api-key
FEDEX_CLIENT_SECRET=your-fedex-secret-key

# Use https://apis-sandbox.fedex.com for test credentials
FEDEX_API_BASE_URL=https://apis.fedex.com

# Shared HTTP Basic Auth credentials that gate the whole app (personal data
# is uploaded here, so it should never be left publicly reachable).
# Leave unset for local development to skip the login prompt.
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
